# voidnews-archive Supabase — sample
# Real values are in .env.local (gitignored). Copy this file to .env.local and fill.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-jwt>

# Server-only — never expose to client bundle
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>
